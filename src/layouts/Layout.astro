---
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import SEO from '../components/common/Seo.astro';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  bodyClass?: string;
}

const {
  title,
  description,
  image,
  bodyClass = '',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Cloudflare Turnstile -->
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

    <!-- Non-blocking Font Awesome -->
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>
    <link
      rel="preload"
      as="style"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      onload="this.onload=null;this.rel='stylesheet'"
      crossorigin
    >
    <noscript>
      <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin>
    </noscript>

    <SEO title={title} description={description} image={image} />
  </head>
  <body class={bodyClass}>
    <Header />
    
    <main class="pt-[73px]">
      <slot />
    </main>
    
    <Footer />

    <script>
      // WebMCP: expose site tools to AI agents running in the browser.
      // https://webmachinelearning.github.io/webmcp/
      if (typeof navigator !== 'undefined' && 'modelContext' in navigator) {
        const origin = location.origin;
        navigator.modelContext.provideContext({
          tools: [
            {
              name: 'get_company_info',
              description: 'Get Greenberry contact details, address, and hours.',
              inputSchema: { type: 'object', properties: {} },
              async execute() {
                return {
                  name: 'Greenberry',
                  email: 'office@greenberry.ie',
                  phone: '+353 83 019 9860',
                  address: 'Duleek, Drogheda, Co. Meath, A92 V0F3, Ireland',
                  website: origin,
                  foundedYear: 2018,
                };
              },
            },
            {
              name: 'list_suites',
              description: 'List Greenberry website suites (parish, club, school, business).',
              inputSchema: { type: 'object', properties: {} },
              async execute() {
                return [
                  { slug: 'parish-websites', url: origin + '/suites/parish-websites' },
                  { slug: 'club-websites', url: origin + '/suites/club-websites' },
                  { slug: 'school-websites', url: origin + '/suites/school-websites' },
                  { slug: 'business-websites', url: origin + '/suites/business-websites' },
                ];
              },
            },
            {
              name: 'navigate_to_page',
              description: 'Navigate the current tab to a Greenberry page (home, about, plans, portfolio, care, contact, or a suite slug).',
              inputSchema: {
                type: 'object',
                required: ['page'],
                properties: {
                  page: {
                    type: 'string',
                    enum: ['home', 'about', 'plans', 'portfolio', 'care', 'contact', 'parish-websites', 'club-websites', 'school-websites', 'business-websites'],
                  },
                },
              },
              async execute({ page }) {
                const map = {
                  home: '/',
                  about: '/about',
                  plans: '/plans',
                  portfolio: '/portfolio',
                  care: '/care',
                  contact: '/contact',
                  'parish-websites': '/suites/parish-websites',
                  'club-websites': '/suites/club-websites',
                  'school-websites': '/suites/school-websites',
                  'business-websites': '/suites/business-websites',
                };
                const path = map[page];
                if (!path) throw new Error('Unknown page: ' + page);
                location.assign(path);
                return { navigatedTo: path };
              },
            },
            {
              name: 'open_contact_form',
              description: 'Open the Greenberry contact form, optionally pre-filling the service of interest.',
              inputSchema: {
                type: 'object',
                properties: {
                  service: { type: 'string', description: 'Service the user is interested in (e.g. "Website Design", "IT Support").' },
                },
              },
              async execute({ service } = {}) {
                const qs = service ? '?service=' + encodeURIComponent(service) : '';
                location.assign('/contact' + qs);
                return { opened: '/contact' + qs };
              },
            },
          ],
        });
      }

      // Dark mode handling
      function initializeDarkMode() {
        const savedTheme = localStorage.getItem('theme');
        if (savedTheme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
          if (!savedTheme) localStorage.setItem('theme', 'light');
        }
      }
      initializeDarkMode();
      window.addEventListener('storage', (e) => {
        if (e.key === 'theme') initializeDarkMode();
      });

      // Smooth scroll for hash links
      document.addEventListener('click', (e) => {
        const link = e.target.closest('a[href^="#"]');
        if (!link) return;
        e.preventDefault();
        const id = link.getAttribute('href');
        if (!id) return;
        document.querySelector(id)?.scrollIntoView({ behavior: 'smooth' });
      });
    </script>

    <style is:global>
      /* Prevent scroll jitter */
      html {
        overflow-x: hidden;
        scroll-behavior: auto; /* Override smooth scroll from CSS */
      }
      
      body {
        overflow-x: hidden;
        min-height: 100dvh;
        background-color: var(--color-white);
        color: var(--color-gray-700);
      }
      
      body.dark {
        background-color: var(--color-gray-900);
        color: var(--color-gray-300);
      }

      /* Smooth theme transitions */
      html.dark-mode-transition,
      html.dark-mode-transition *,
      html.dark-mode-transition *:before,
      html.dark-mode-transition *:after {
        transition: background-color 300ms ease, border-color 300ms ease, color 300ms ease !important;
        transition-delay: 0 !important;
      }
    </style>
  </body>
</html>